{
  "include": ["**/*.mts", ".github/**/*.mts", "**/*.js", ".github/**/*.js"],
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "useUnknownInCatchVariables": false,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true,
    "noEmit": true,
    // Node needs the .ts extensions to run properly
    "allowImportingTsExtensions": true,
    // TODO: convert js files to mts
    "allowJs": true,
    "checkJs": true
  }
}
